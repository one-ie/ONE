  <section>
    <container>
      <div class="container mx-auto px-4 md:px-0">
        <article class="prose max-w-none py-12 lg:prose-xl">
          <slot />
        </article>
      </div>
    </container>
  </section>
  <Footer />
</BaseLayout>
