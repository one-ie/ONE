// Tailwind
@import 'tailwindcss/base.css'
@import 'tailwindcss/components.css'
@import 'tailwindcss/utilities.css'

// Colors
primaryColor = #3490dc // blue
secondaryColor = #f6ad55 // orange
accentColor = #9f7aea // purple
neutralColor = #a0aec0 // gray

// Function to darken colors
darkenColor(color, amount) 
  darken(color, amount)

// Focus
.focus-primary
  background-color darkenColor(primaryColor, 70%)

.focus-secondary
  background-color darkenColor(secondaryColor, 10%)

.focus-accent
  background-color darkenColor(accentColor, 10%)

.focus-neutral
  background-color darkenColor(neutralColor, 10%)

// Borders
.border-primary
  border-color darkenColor(primaryColor, 30%)

.border-secondary
  border-color darkenColor(secondaryColor, 30%)

.border-accent
  border-color darkenColor(accentColor, 30%)

.border-neutral
  border-color darkenColor(neutralColor, 30%)

primary-background = url("/dark-primary-background.png")
secondary-background = url("/brilliant.png")

[data-theme='ONE']
  --background-primary url("/dark-primary-background.png")
  --background-secondary url("/brilliant.png")
  --pattern-secondary white
  --logo url("/src/assets/images/logos/ONE.svg")

[data-theme='TWO']
  --color-default white
  --background-primary url("/light-primary-background.png")
  --background-secondary url("/transparent-background.png")
  --logo url("/images/logos/ONE-black.svg")

[data-theme='hilltribe']
  --color-default #27372E
  --primary-content red
  --background-primary url("/dark-primary-background.png")
  --background-secondary url("/transparent-background.png")
  --logo url("/src/assets/images/hilltribe/logo-icon.png")

.base-100
  background-color: purple

.red
  background-color: red
//Header
header
  padding: 10px
.logo
  display: block;
  -moz-box-sizing: border-box;
  box-sizing: border-box;
  background: var(--logo) no-repeat;
  width: 50px; /* Width of new image */
  height: 50px; /* Height of new image */
  padding-left: 125px; /* Equal to width of new image */
  padding-top: 20px

//Links

.link-underline
  border-bottom-width 0
  background-image linear-gradient(transparent, transparent), linear-gradient(#fff, #fff)
  background-size 0 3px
  background-position 0 100%
  background-repeat no-repeat
  transition background-size 0.5s ease-in-out

.link-underline-black
  background-image linear-gradient(transparent, transparent), linear-gradient(#1a5fb4, #1a5fb4)

.link-underline:hover
  background-size 100% 3px
  background-position 0 100%

//Headings
h1, .h1, h2, .h2, h3, .h3, h4, .h4, h5, .h5, h6, .h6
  font-family font-secondary, sans-serif
  font-weight bold
  line-height tight
  color white

h1, .h1
  font-size 40px
  font-weight 600

h2, .h2
  font-size 2rem

h3, .h3
  font-size 1.5rem

h4, .h4
  font-size 1.25rem

h5, .h5
  font-size 1.125rem

h6, .h6
  font-size 1rem

section#channels
  padding : 40px 0

